{
  "name": "claude-channel-telegram",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "type": "module",
  "bin": "./server.ts",
  "scripts": {
    "start": "bun install --no-summary && bun server.ts",
    "build": "bun build ./server.ts --target bun --outdir ./dist",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx @biomejs/biome check ./server.ts",
    "lint:fix": "bunx @biomejs/biome check --write ./server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "grammy": "^1.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "typescript": "^5.5.0",
    "@types/bun": "latest"
  }
}
